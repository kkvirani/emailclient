# ─────────────────────────────────────────────────────────────────────────────
# Database (matches docker-compose.yml)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postal:postal@localhost:5432/postal?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# Auth.js
#   Generate a secret with:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────
AUTH_SECRET="replace-me-with-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Restrict sign-in to the single owner (your email).
OWNER_EMAIL="you@example.com"

# ─────────────────────────────────────────────────────────────────────────────
# Token vault encryption (AES-256-GCM)
#   Must be 32 bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY="replace-me-32-byte-base64-key"

# ─────────────────────────────────────────────────────────────────────────────
# Provider OAuth (filled in Phase 2)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI (filled in Phase 7) — server-only, never exposed to the browser
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
