// Postal — Prisma schema
// See docs/03-DATABASE-SCHEMA.md for the conceptual model.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pg_trgm]
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum Provider {
  gmail
  outlook
  imap
}

enum AccountStatus {
  active
  error
  disconnected
}

enum FolderType {
  inbox
  sent
  drafts
  archive
  spam
  trash
  custom
}

enum Category {
  personal
  work
  newsletter
  receipt
  invoice
  finance
  travel
  social
  promotion
  spam
  other
}

enum SubscriptionStatus {
  active
  unsubscribed
  blocked
  failed
}

enum PostUnsubscribeAction {
  none
  archive
  delete
  label
}

enum RuleMatchType {
  all
  any
}

enum RuleConditionField {
  from
  to
  subject
  body
  has_attachment
  list_id
  category
}

enum RuleOperator {
  contains
  equals
  matches
  gt
  lt
}

enum RuleActionType {
  move
  archive
  delete
  label
  tag
  mark_important
  mark_read
}

enum LabelType {
  system
  user
}

enum SyncStatus {
  idle
  syncing
  error
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth / User
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts    Account[]
  smartViews  SmartView[]
  auditLogs   AuditLog[]
  authAccounts AuthAccount[]
  sessions    Session[]
}

// Auth.js adapter models (provider login for the app itself)
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────────────────────
// Connected mailbox accounts
// ─────────────────────────────────────────────────────────────────────────────

model Account {
  id               String        @id @default(cuid())
  userId           String
  provider         Provider
  emailAddress     String
  displayName      String?
  status           AccountStatus @default(active)
  color            String?
  isUnifiedDefault Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthToken    OAuthToken?
  imapCred      ImapCredential?
  folders       Folder[]
  threads       Thread[]
  messages      Message[]
  labels        Label[]
  subscriptions Subscription[]
  rules         Rule[]
  syncStates    SyncState[]

  @@unique([userId, emailAddress])
  @@index([userId])
}

model OAuthToken {
  id           String   @id @default(cuid())
  accountId    String   @unique
  // AES-256-GCM encrypted fields
  accessToken  String   @db.Text
  refreshToken String?  @db.Text
  iv           String
  authTag      String
  keyVersion   Int      @default(1)
  expiresAt    DateTime?
  scope        String?
  updatedAt    DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model ImapCredential {
  id         String  @id @default(cuid())
  accountId  String  @unique
  host       String
  port       Int
  secure     Boolean @default(true)
  username   String
  // encrypted password
  password   String  @db.Text
  iv         String
  authTag    String
  keyVersion Int     @default(1)
  smtpHost   String?
  smtpPort   Int?
  smtpSecure Boolean @default(true)
  updatedAt  DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// Mailbox structure
// ─────────────────────────────────────────────────────────────────────────────

model Folder {
  id               String     @id @default(cuid())
  accountId        String
  providerFolderId String
  name             String
  type             FolderType @default(custom)
  parentId         String?
  unreadCount      Int        @default(0)
  totalCount       Int        @default(0)

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent   Folder?   @relation("FolderTree", fields: [parentId], references: [id])
  children Folder[]  @relation("FolderTree")
  messages Message[]

  @@unique([accountId, providerFolderId])
  @@index([accountId, type])
}

model Label {
  id              String    @id @default(cuid())
  accountId       String
  providerLabelId String?
  name            String
  color           String?
  type            LabelType @default(user)

  account       Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messageLabels MessageLabel[]
  subscriptions Subscription[]

  @@unique([accountId, name])
  @@index([accountId])
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  color       String?
  messageTags MessageTag[]
}

// ─────────────────────────────────────────────────────────────────────────────
// Threads & Messages
// ─────────────────────────────────────────────────────────────────────────────

model Thread {
  id            String   @id @default(cuid())
  accountId     String
  subject       String?
  snippet       String?
  lastMessageAt DateTime
  messageCount  Int      @default(1)
  hasUnread     Boolean  @default(true)
  isStarred     Boolean  @default(false)
  participants  Json     @default("[]")

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([accountId, lastMessageAt])
}

model Message {
  id                 String    @id @default(cuid())
  accountId          String
  threadId           String?
  providerMessageId  String
  folderId           String?

  fromName  String?
  fromEmail String
  to        Json    @default("[]")
  cc        Json    @default("[]")
  bcc       Json    @default("[]")
  subject   String?
  snippet   String?

  sentAt     DateTime?
  receivedAt DateTime

  isRead        Boolean @default(false)
  isStarred     Boolean @default(false)
  isImportant   Boolean @default(false)
  hasAttachments Boolean @default(false)
  sizeBytes     Int     @default(0)

  listUnsubscribe     String? @db.Text
  listUnsubscribePost String?
  listId              String?

  category           Category? 
  categoryConfidence Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  thread      Thread?         @relation(fields: [threadId], references: [id])
  folder      Folder?         @relation(fields: [folderId], references: [id])
  body        MessageBody?
  embedding   MessageEmbedding?
  attachments Attachment[]
  labels      MessageLabel[]
  tags        MessageTag[]

  @@unique([accountId, providerMessageId])
  @@index([accountId, folderId, receivedAt])
  @@index([accountId, isRead])
  @@index([accountId, fromEmail])
  @@index([accountId, category])
}

model MessageBody {
  messageId String  @id
  html      String? @db.Text
  text      String? @db.Text

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageEmbedding {
  messageId String   @id
  // pgvector column added via raw SQL migration (Prisma lacks a native vector type).
  // Declared as Unsupported so Prisma is aware of it.
  embedding Unsupported("vector(1536)")?
  model     String   @default("text-embedding-3-small")
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Attachment {
  id                  String  @id @default(cuid())
  messageId           String
  filename            String
  mimeType            String
  sizeBytes           Int     @default(0)
  providerAttachmentId String?
  contentId           String?

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessageLabel {
  messageId String
  labelId   String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  label   Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([messageId, labelId])
}

model MessageTag {
  messageId String
  tagId     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([messageId, tagId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Unsubscribe center
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id                  String                @id @default(cuid())
  accountId           String
  senderEmail         String
  senderDomain        String
  senderName          String?
  messageCount        Int                   @default(0)
  firstReceivedAt     DateTime?
  lastReceivedAt      DateTime?
  estMonthlyVolume    Float                 @default(0)
  isNewsletter        Boolean               @default(false)
  confidence          Float                 @default(0)
  unsubscribeUrl      String?               @db.Text
  unsubscribeMailto   String?
  supportsOneClick    Boolean               @default(false)
  status              SubscriptionStatus    @default(active)
  postUnsubscribeAction PostUnsubscribeAction @default(none)
  labelId             String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  label   Label?  @relation(fields: [labelId], references: [id])

  @@unique([accountId, senderEmail])
  @@index([accountId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Rules engine
// ─────────────────────────────────────────────────────────────────────────────

model Rule {
  id        String        @id @default(cuid())
  accountId String
  name      String
  enabled   Boolean       @default(true)
  matchType RuleMatchType @default(all)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  account    Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conditions RuleCondition[]
  actions    RuleAction[]

  @@index([accountId])
}

model RuleCondition {
  id       String             @id @default(cuid())
  ruleId   String
  field    RuleConditionField
  operator RuleOperator
  value    String

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model RuleAction {
  id     String         @id @default(cuid())
  ruleId String
  type   RuleActionType
  value  String?

  rule Rule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

// ─────────────────────────────────────────────────────────────────────────────
// Smart views, sync state, audit
// ─────────────────────────────────────────────────────────────────────────────

model SmartView {
  id       String  @id @default(cuid())
  userId   String
  name     String
  icon     String?
  query    Json    @default("{}")
  order    Int     @default(0)
  isSystem Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SyncState {
  id           String     @id @default(cuid())
  accountId    String
  folderId     String?
  cursor       String?    @db.Text
  uidValidity  String?
  modSeq       String?
  lastSyncedAt DateTime?
  status       SyncStatus @default(idle)
  error        String?    @db.Text

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, folderId])
  @@index([accountId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  target    Json     @default("{}")
  result    String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
